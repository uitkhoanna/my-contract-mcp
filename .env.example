# Cysic Minimax API configuration
# The server reads these via process.env.* (never hardcoded).
# Copy this file to ".env" and fill in your real key, or set the env vars
# in your MCP client config (Claude Desktop, Cursor, etc.).

# Required: API key for the Cysic Minimax token-gated endpoint.
# Get one from the Cysic token-ai dashboard.
CYSIC_API_KEY=

# Optional overrides (defaults shown).
# CYSIC_BASE_URL=https://token-ai.cysic.xyz/v1
# CYSIC_MODEL=minimax-m3
# CYSIC_TIMEOUT_MS=60000
